  "signal_signatures": [
    {
      "signal_id": "SIG_VLQ_BB",
      "model": "vector-like B-quark pair production",
      "production_mode": "pair production",
      "benchmark_scenarios": [
        "SU(2) singlet branching ratios",
        "branching-ratio-independent scan"
      ],
      "decay_modes_considered": [
        "B -> Wt",
        "B -> Hb",
        "B -> Zb"
      ],
      "representative_multilepton_topologies": [
