      ],
      "decay_modes_considered": [
        "T5/3 -> Wt"
      ],
      "branching_ratio_assumption": "B(T5/3 -> Wt) = 100%",
      "target_region_family": "VLQ_4top",
      "target_final_state_signature": "same-sign dilepton or trilepton plus b-jets",
      "sensitivity_note": "A same-sign lepton pair can arise from a single T5/3 decay when both W bosons decay leptonically."
    },
    {
      "signal_id": "SIG_4TOP_SM",
      "model": "Standard Model four-top-quark production",
      "production_mode": "SM production",
      "target_region_family": "VLQ_4top",
      "target_final_state_signature": "same-sign dilepton or trilepton plus b-jets",
      "reported_branching_ratio_to_target_final_state": "12.1%, including leptonically decaying tau leptons"
    },
    {
      "signal_id": "SIG_4TOP_CI",
      "model": "BSM four-top-quark production via contact interaction",
      "production_mode": "effective four-fermion contact interaction",
      "operator_choice": "right-handed top-quark operator only",
      "target_region_family": "VLQ_4top",
      "target_final_state_signature": "same-sign dilepton or trilepton plus b-jets"
    },
    {
      "signal_id": "SIG_4TOP_2UED_RPP",
      "model": "BSM four-top-quark production in 2UED/RPP",
      "production_mode": "pair production of tier (1,1) states followed by cascades to A(1,1) -> ttbar",
      "key_model_parameters": [
        "mKK = 1/R4",
        "xi = R4/R5"
      ],
      "branching_ratio_assumption": "B(A(1,1) -> ttbar) = 100%",
      "target_region_family": "VLQ_4top",
      "target_final_state_signature": "same-sign dilepton or trilepton plus b-jets, with additional associated SM objects possible"
    },
    {
      "signal_id": "SIG_4TOP_2HDM",
      "model": "BSM four-top-quark production in type-II 2HDM",
      "production_mode": "gg -> ttH/A with H/A -> ttbar",
      "benchmark_scenarios": [
        "heavy scalar H only",
        "degenerate heavy scalar and pseudo-scalar H/A"
      ],
      "key_model_parameters": [
        "mH or mH/A",
        "tan(beta)"
      ],
      "target_region_family": "VLQ_4top",
      "target_final_state_signature": "same-sign dilepton or trilepton plus b-jets",
      "kinematic_note": "The paper states that this benchmark is softer than the contact-interaction four-top signature, especially at low masses."
    },
    {
      "signal_id": "SIG_SSTT_DM",
      "model": "same-sign top-quark pair production in an FCNC dark-matter mediator model",
      "production_modes": [
        "prompt tt production",
        "on-shell s-channel mediator production",
        "off-shell s-channel mediator production"
      ],
      "key_model_parameters": [
        "mediator mass mV",
        "coupling to SM particles gSM",
        "coupling to dark-matter particles gDM"
      ],
      "target_region_family": "same_sign_tt",
      "target_final_state_signature": "exactly two positively charged leptons plus b-jets",
      "selection_specific_note": "Only positively charged lepton pairs are used because tt production is much larger than tbar tbar production in pp collisions."
    }
